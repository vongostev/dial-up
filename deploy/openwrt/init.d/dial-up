#!/bin/sh /etc/rc.common

USE_PROCD=1
START=99

start_service() {
    [ -f /etc/dial-up.env ] && . /etc/dial-up.env
    export VK_TOKEN OLCRTC_KEY IS_CLIENT DEBUG OLCRTC_EXE DATA_DIR LAST_PROVIDER_FILE ALLOWED_USER_IDS SLEEP_ON_ERROR STATUS_PORT SOCKS_PROXY_ADDR SOCKS_PROXY_PORT SOCKS_PROXY_USER SOCKS_PROXY_PASS

    procd_open_instance
    procd_set_param command /usr/bin/dial-up
    procd_set_param env "VK_TOKEN=$VK_TOKEN" "OLCRTC_KEY=$OLCRTC_KEY" "IS_CLIENT=$IS_CLIENT" "DEBUG=$DEBUG" "OLCRTC_EXE=$OLCRTC_EXE" "DATA_DIR=$DATA_DIR" "LAST_PROVIDER_FILE=$LAST_PROVIDER_FILE" "ALLOWED_USER_IDS=$ALLOWED_USER_IDS" "SLEEP_ON_ERROR=$SLEEP_ON_ERROR" "STATUS_PORT=${STATUS_PORT:-9091}" "SOCKS_PROXY_ADDR=$SOCKS_PROXY_ADDR" "SOCKS_PROXY_PORT=$SOCKS_PROXY_PORT" "SOCKS_PROXY_USER=$SOCKS_PROXY_USER" "SOCKS_PROXY_PASS=$SOCKS_PROXY_PASS"
    procd_set_param respawn
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}