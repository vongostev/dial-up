# dial-up environment variables
# Copy this file to /etc/dial-up.env and fill in your values.

VK_TOKEN=your_vk_user_token_here (it is very long)
OLCRTC_KEY=your_openssl_rand_hex_32_here

# Set to false for server mode
IS_CLIENT=true

# Set to true for debug logging
DEBUG=false

# Path to the olcrtc binary
OLCRTC_EXE=/etc/olcrtc-linux-arm64

# Data directory
DATA_DIR=data

# Last provider persistence file
LAST_PROVIDER_FILE=last_provider.json

# Comma-separated VK user IDs (empty = allow all)
ALLOWED_USER_IDS=

# Seconds to sleep after error recovery
SLEEP_ON_ERROR=5

# Local HTTP status endpoint port for the LuCI panel (loopback only, 127.0.0.1)
# Default 9091 (9090 is reserved for the sing-box Clash API).
STATUS_PORT=9091

# ── Server-only: upstream SOCKS5 egress (ignored in client mode) ──
# Empty SOCKS_PROXY_ADDR = direct egress (no upstream proxy).
# Empty SOCKS_PROXY_USER = no-auth SOCKS5 (RFC 1929 method 0x00).
# SOCKS_PROXY_ADDR=
# SOCKS_PROXY_PORT=
# SOCKS_PROXY_USER=
# SOCKS_PROXY_PASS=
