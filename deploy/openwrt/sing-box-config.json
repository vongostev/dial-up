{
  "log": {
    "timestamp": true,
    "level": "info"
  },
  "dns": {
    "servers": [
      { "type": "local", "tag": "local" },
      { "type": "udp", "tag": "yandex", "server": "77.88.8.8" }
    ],
    "rules": [
      {
        "domain_suffix": ["local", ".lan", ".internal"],
        "server": "local"
      }
    ],
    "final": "yandex"
  },
  "inbounds": [
    {
      "type": "tproxy",
      "tag": "tproxy-in",
      "listen": "0.0.0.0",
      "listen_port": 2080
    }
  ],
  "outbounds": [
    {
      "type": "socks",
      "tag": "proxy",
      "server": "127.0.0.1",
      "server_port": 1080
    },
    {
      "type": "direct",
      "tag": "direct",
      "domain_resolver": "yandex"
    },
    {
      "type": "selector",
      "tag": "route-select",
      "default": "direct",
      "outbounds": ["proxy", "direct"]
    }
  ],
  "route": {
    "rule_set": [
      {
        "tag": "whitelist",
        "type": "local",
        "format": "source",
        "path": "/etc/sing-box/whitelist.json"
      }
    ],
    "rules": [
      {
        "action": "sniff",
        "timeout": "300ms",
        "override_destination": true
      },
      {
        "domain_suffix": ["local", ".lan", ".internal"],
        "action": "route",
        "outbound": "direct"
      },
      {
        "rule_set": "whitelist",
        "action": "route",
        "outbound": "direct"
      }
    ],
    "final": "route-select",
    "auto_detect_interface": true
  },
  "experimental": {
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "",
      "secret": "",
      "default_mode": "route-select"
    }
  }
}
